# Database (local dev: Homebrew Postgres; production: Neon/hosted)
DATABASE_URL=postgres://USER@localhost:5432/content_team

# Auth.js
AUTH_SECRET=            # openssl rand -base64 32
AUTH_URL=http://localhost:3000   # production: https://your-domain

# Google OAuth (sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Calendar service account (domain-wide delegation)
# Local dev: google-service-account.local.json file in the project root.
# Hosted: the key JSON in this env var (raw JSON or base64).
GOOGLE_SERVICE_ACCOUNT_KEY=

# Cron endpoint protection (Vercel sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Calendar webhooks (activate post-deploy; needs public https)
APP_URL=
WEBHOOK_CHANNEL_TOKEN=  # openssl rand -hex 24

# Email (pending Resend key — stubbed until set)
# RESEND_API_KEY=
